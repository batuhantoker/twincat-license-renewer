# Copy this file to `.env` and edit as needed. Values left blank or
# commented out will use the built-in defaults.

# ---- Paths ----------------------------------------------------------------

# TwinCAT XAE Shell executable. The script also scans a few common
# install locations if this isn't set, so you usually don't need to
# override it.
# XAE_SHELL_EXE=C:\Program Files (x86)\Beckhoff\TcXaeShell\Common7\IDE\TcXaeShell.exe

# Tesseract OCR executable. The winget UB-Mannheim build installs here
# by default.
# TESSERACT_EXE=C:\Program Files\Tesseract-OCR\tesseract.exe

# ---- Behavior -------------------------------------------------------------

# How many fresh captchas to try before giving up. Each retry cancels the
# current captcha dialog and reopens it to get a new image, so Tesseract
# gets a different input each time. 8 is usually plenty.
# OCR_MAX_RETRIES=8

# Per-step upper bound (in seconds) for waiting on a UI control to
# appear. Most steps finish well under this.
# STEP_TIMEOUT_S=15
